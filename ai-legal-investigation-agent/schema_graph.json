{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Legal Reasoning Graph",
  "type": "object",
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "label": { "type": "string" }
        },
        "required": ["id", "type"]
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "type": { "type": "string" }
        },
        "required": ["from", "to", "type"]
      }
    }
  },
  "required": ["nodes", "relations"]
}